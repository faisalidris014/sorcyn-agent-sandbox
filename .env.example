# ============================================================
# Reverse Marketplace / Sorcyn — Local Dev Environment Variables
# ============================================================
# Copy this file to backend/.env (or .env at repo root) and fill in values.
# For production, see .env.production.example — production has its own file
# because validateProductionEnv() in backend/src/config/env.ts refuses to
# start when several of these are unset.
# ============================================================

# ── Core ───────────────────────────────────────────────────��
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Database (PostgreSQL) ───────────────────────────────────
# Port 5433 must match the postgres host port in docker-compose.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/reverse_marketplace
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/reverse_marketplace

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (min 64 chars in production) ────────────────
JWT_ACCESS_SECRET=dev_access_secret_change_me_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_with_openssl_rand_base64_64
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Stripe (optional in dev; REQUIRED in production) ────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_RETURN_URL=reversemarket://seller/stripe/complete
STRIPE_CONNECT_REFRESH_URL=reversemarket://seller/stripe/refresh
# Payment-processor outage kill switch (RUNBOOK_OPS.md §2). true = degrade mode.
STRIPE_DEGRADED=false

# ── Cloudflare R2 (optional in dev) ─────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=reverse-marketplace
R2_PUBLIC_URL=

# ── Resend (optional in dev — emails stub when unset) ─────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@sorcyn.com
RESEND_FROM_NAME=Sorcyn

# ── Google Maps (optional in dev) ───────────────────────────
GOOGLE_MAPS_API_KEY=

# ── AI (Google Gemini) ──────────────────────────────────────
GEMINI_API_KEY=

# ── Firebase Cloud Messaging (push — stubbed when unset) ────
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ── Sentry (Error Tracking + Performance — Phase 4 D-05) ────
SENTRY_DSN=
# Optional override of production traces sample rate. Defaults to 0.05 (5%)
# in production to stay inside Sentry Team plan quota at MVP traffic
# (RESEARCH §3 / Pitfall 6). Leave unset in dev/test (defaults to 1.0).
SENTRY_TRACES_SAMPLE_RATE=0.05

# ── Better Stack centralized logging (Phase 4 D-07) ─────────
# REQUIRED in production — backend refuses to start without it.
# Source token is created at Better Stack → Sources → Sorcyn API.
BETTER_STACK_TOKEN=
BETTER_STACK_INGEST_URL=https://in.logs.betterstack.com

# ── App URLs ─────────────────────────────────────────────────
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080

# ── Monitoring ──────────────────────────────────────────────
# Bearer token to protect /metrics endpoint (Prometheus scraper)
METRICS_TOKEN=

# ── Feature flags ───────────────────────────────────────────
ENABLE_SWAGGER=true
