{
  "name": "reverse-marketplace-api",
  "version": "1.0.0",
  "description": "Reverse Marketplace API — buyers post needs, sellers compete to fulfill",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:coverage:unit": "vitest run --coverage --coverage.reportsDirectory=coverage/unit tests/unit",
    "test:coverage:integration": "vitest run --coverage --coverage.reportsDirectory=coverage/integration tests/integration",
    "test:coverage:e2e": "vitest run --coverage --coverage.reportsDirectory=coverage/e2e tests/e2e",
    "test:audit": "vitest run tests/audit",
    "test:stripe": "vitest run tests/stripe-integration.test.ts",
    "validate": "npm run typecheck && npm run test:run",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-cold-start": "tsx scripts/seed-cold-start.ts",
    "db:backfill-products": "tsx scripts/backfill-products-category.ts",
    "db:backfill-subcategories": "tsx scripts/backfill-post-subcategories.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:bootstrap": "bash scripts/bootstrap-db.sh",
    "db:doctor": "tsx scripts/db-doctor.ts",
    "db:reset-lockout": "bash scripts/clear-login-lockout.sh",
    "contract:generate": "tsx scripts/dump-openapi.ts",
    "contract:check": "tsx scripts/check-openapi.ts",
    "doctor": "../scripts/check-prereqs.sh",
    "bootstrap": "../scripts/check-prereqs.sh && npm install && npm run db:bootstrap"
  },
  "keywords": [
    "marketplace",
    "reverse-marketplace",
    "fastify",
    "prisma"
  ],
  "author": "",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@google/generative-ai": "^0.24.1",
    "@logtail/pino": "^0.5.8",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@sentry/node": "^10.49.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.69.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "firebase-admin": "^13.6.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^20.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "prisma": "^7.4.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
