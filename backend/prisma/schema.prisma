}

model UploadHash {
  id          String   @id @default(uuid()) @map("upload_hash_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  category    String   @db.VarChar(50)
  contentHash String   @map("content_hash") @db.VarChar(64)
  key         String   @db.VarChar(500)
  publicUrl   String   @map("public_url") @db.VarChar(1000)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, contentHash])
  @@index([userId, category, contentHash])
  @@map("upload_hashes")
}

// Perceptual-hash blocklist for copyright takedown + staydown (#313).
// Each row is an image an admin took down. Lookup is fuzzy (Hamming distance on
// perceptualHash), so it is a linear scan + distance check, NOT a unique-index hit.
// Immutable audit trail; uploader/admin/post are stored as plain UUIDs (no FK
// relations) since users are soft-deleted and the row must survive them.
model ImageTakedown {
  id             String   @id @default(uuid()) @map("takedown_id") @db.Uuid
  perceptualHash String   @map("perceptual_hash") @db.VarChar(16)
  hashAlgo       String   @default("dhash-64") @map("hash_algo") @db.VarChar(20)
  imageKey       String   @map("image_key") @db.VarChar(500)
  sourcePostId   String?  @map("source_post_id") @db.Uuid
  sourceOfferId  String?  @map("source_offer_id") @db.Uuid
  uploaderUserId String   @map("uploader_user_id") @db.Uuid
  takenDownBy    String   @map("taken_down_by") @db.Uuid
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([uploaderUserId])
  @@index([createdAt(sort: Desc)])
  @@map("image_takedowns")
}

// Operator-controlled in-app announcement banner (#85).
// Drives the global Flutter banner during incidents (see docs/RUNBOOK_OPS.md §2, §5).
model SystemAnnouncement {
  id        String               @id @default(uuid()) @map("announcement_id") @db.Uuid

  message   String               @db.VarChar(500)
  severity  AnnouncementSeverity @default(info)

  // Active window: live when now() in [startsAt, endsAt). endsAt null = open-ended.
  startsAt  DateTime             @default(now()) @map("starts_at")
  endsAt    DateTime?            @map("ends_at")

  // Actor (admin user id). Plain column — no FK, keeps the migration purely additive.
  createdBy String               @map("created_by") @db.Uuid

  createdAt DateTime             @default(now()) @map("created_at")
  // Cleared by hard delete (DELETE endpoint) — no soft-delete column needed.

  @@index([startsAt])
  @@index([endsAt])
  @@map("system_announcements")
}
