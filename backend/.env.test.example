# ─────────────────────────────────────────────────────────────────────────────
# Test environment template (issue #133)
#
# This file is the TEMPLATE. Do not edit `.env.test` by hand — it is per-machine
# and gitignored. Run `npm run db:bootstrap`, which DERIVES `.env.test` from your
# dev `.env` (it swaps the database name to `reverse_marketplace_test` so the
# Postgres user/host match your machine) and copies the test-only values below.
#
# The whole point: tests run against `reverse_marketplace_test`, NEVER your dev
# `reverse_marketplace`. A guard in tests/db-guard.ts refuses to run if NODE_ENV
# is not "test" or the DB name does not end in "_test".
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=test

# Dedicated test database — name MUST end in "_test" (enforced by tests/db-guard.ts).
# bootstrap-db.sh rewrites the user/host portion to match your dev DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reverse_marketplace_test

# Separate logical Redis DB (index 1) so test login-lockout keys never collide
# with your dev Redis (index 0).
REDIS_URL=redis://localhost:6379/1

# Test-only JWT secrets (≥32 chars). Not secret — local test fixtures only.
JWT_ACCESS_SECRET=test-access-secret-that-is-at-least-32-chars-long
JWT_REFRESH_SECRET=test-refresh-secret-that-is-at-least-32-chars-long
JWT_ACCESS_EXPIRES_IN=45s
