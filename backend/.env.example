# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Database (PostgreSQL) — SINGLE SOURCE OF TRUTH for local DB config.
# This DATABASE_URL drives dev, migrations, and seeding. The TEST database is
# DERIVED from it (name → "<dbname>_test") by `npm run db:bootstrap`, which
# writes .env.test — so you never hand-maintain a second URL and the Postgres
# user/host always matches your machine. Full reference: docs/DATABASE_CONFIG.md.
#
# Pick the form that matches your local Postgres:
#   • Homebrew/native (macOS): use your OS superuser, no password (peer auth):
DATABASE_URL=postgresql://YOUR_OS_USER@localhost:5432/reverse_marketplace
#   • Docker Postgres: use the postgres role. Port 5433 (NOT 5432) — that is the
#     host port docker-compose.yml maps the postgres container to. Enforced by
#     backend/tests/audit/env-example-parity.test.ts so it can never drift again.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/reverse_marketplace
#
# Shared Supabase dev DB (issue #214) + staging/production:
# DO NOT put these in .env — set them in the SHARED Doppler `dev` config so both
# operators inherit the same database (and keep your LOCAL .env DATABASE_URL above
# pointed at local Postgres, which is what the TEST suite uses). `db:bootstrap`
# refuses to run if .env's DATABASE_URL points at Supabase. See docs/DATABASE_CONFIG.md.
#   • Pooled / transaction pooler (port 6543) → DATABASE_URL (app runtime):
#       doppler secrets set DATABASE_URL='postgresql://postgres.[project]:[password]@aws-[n]-[region].pooler.supabase.com:6543/postgres?sslmode=require'
#   • Direct connection (port 5432) → DIRECT_DATABASE_URL (migrations only — the
#     pooler can't run migrations; prisma.config.ts prefers this when set):
#       doppler secrets set DIRECT_DATABASE_URL='postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?sslmode=require'

# Realtime work-claim sync (devsync) — POINTS AT THE SHARED Supabase, not your
# local dev DB. This is how both operators' AI agents see each other's in-flight
# edits in realtime (see docs/REALTIME_SYNC.md). Both Faisal and Mohamed set this
# to the SAME shared Supabase connection string. Leave unset to disable the
# realtime layer (the hooks fail open — coding is never blocked).
# SYNC_DATABASE_URL=postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me-256-bits-minimum
JWT_REFRESH_SECRET=your-refresh-secret-change-me-256-bits-minimum
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Stripe Connect
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_CONNECT_CLIENT_ID=ca_your_client_id
STRIPE_CONNECT_RETURN_URL=reversemarket://seller/stripe/complete
STRIPE_CONNECT_REFRESH_URL=reversemarket://seller/stripe/refresh
# Payment-processor outage kill switch (RUNBOOK_OPS.md §2). true = degrade mode.
STRIPE_DEGRADED=false

# Object storage (S3-compatible). Production = Cloudflare R2; local dev = MinIO.
#
# Local dev (default below): run `docker compose up -d minio` and leave the three
# R2 credential vars commented/unset. storage.ts then falls back to local MinIO
# (http://localhost:9000, minioadmin/minioadmin); the bucket is created by the
# minio-setup service. R2_PUBLIC_URL points the app at the MinIO bucket so it can
# load uploaded images. (Do NOT set R2_ACCOUNT_ID to a placeholder — any truthy
# value disables the MinIO fallback and breaks dev uploads.)
R2_BUCKET_NAME=reverse-marketplace
R2_PUBLIC_URL=http://localhost:9000/reverse-marketplace
#
# Production (Cloudflare R2) — set all four via Doppler, and use the r2.dev URL:
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_PUBLIC_URL=https://your-bucket.r2.dev

# Resend (transactional email)
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=noreply@sorcyn.com
RESEND_FROM_NAME=Sorcyn

# Firebase Cloud Messaging (push notifications)
FCM_PROJECT_ID=your-project-id
FCM_PRIVATE_KEY=your-private-key
FCM_CLIENT_EMAIL=your-client-email

# Google Maps
GOOGLE_MAPS_API_KEY=your-api-key

# AI (Gemini Flash-Lite for MVP)
GEMINI_API_KEY=your-gemini-api-key

# Sentry (error tracking)
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Monitoring
METRICS_TOKEN=your-metrics-bearer-token

# App
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080

# Feature flags
ENABLE_SWAGGER=false  # Set true to expose /docs in production
