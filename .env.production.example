# ============================================================
# Reverse Marketplace — Production Environment Variables
# ============================================================
# Copy this file to backend/.env.production and fill in all values.
# docker-compose.production.yml reads from backend/.env.production
#
# Generate secrets with: openssl rand -base64 64
# ============================================================

# ── Core ───��─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Database (PostgreSQL 15) ─────────────────────────────────
# Used by the API server (Prisma)
DATABASE_URL=postgresql://rm_user:CHANGE_ME@postgres:5432/reverse_marketplace?sslmode=prefer

# Used by docker-compose.production.yml to initialize PostgreSQL
POSTGRES_USER=rm_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=reverse_marketplace

# ── Redis 7 ──────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME

# ── JWT Secrets (min 64 characters recommended) ──────────────
# Generate: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Stripe (REQUIRED in production) ─────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...
STRIPE_CONNECT_RETURN_URL=https://yourdomain.com/stripe/return
STRIPE_CONNECT_REFRESH_URL=https://yourdomain.com/stripe/refresh

# ── Cloudflare R2 (File Storage) ────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=reverse-marketplace
R2_PUBLIC_URL=https://files.yourdomain.com

# ── SendGrid (Email) ────────────────────────────────────────
SENDGRID_API_KEY=SG.your_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Reverse Marketplace

# ── Google Maps ──────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ── AI (Google Gemini) ───────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Firebase Cloud Messaging (Push Notifications) ────────────
FCM_PROJECT_ID=your-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Sentry (Error Tracking) ─────────────────────────────────
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── App URLs ─────────────────────────────────────────────────
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Monitoring (Optional) ──────────��────────────────────────
# Bearer token to protect /metrics endpoint (Prometheus scraper)
# Generate: openssl rand -hex 32
METRICS_TOKEN=
